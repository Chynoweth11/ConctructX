{
  "name": "constructx",
  "version": "2.0.0",
  "private": true,
  "description": "ConstructX website — TypeScript frontend, dependency-free Python server.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "images": "python3 tools/build_images.py",
    "start": "python3 app.py",
    "dev": "npm run build && python3 app.py",
    "test": "python3 -m unittest discover -s tests -v",
    "check": "npm run typecheck && npm test"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=18"
  }
}
