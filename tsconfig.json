{
  "compilerOptions": {
    "target": "ES2020",
    "module": "preserve",
    "lib": ["DOM", "ES2020"],
    "rootDir": "frontend/src",
    "outDir": "assets/js",
    "strict": false,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "sourceMap": false
  },
  "include": ["frontend/src/**/*.ts"]
}
