# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs and temp files
*.log
*.tmp
*.bak

# Private runtime form submissions — never commit client enquiries
data/

# Python
__pycache__/
*.py[cod]
.python-version
.venv/
venv/

# Node
node_modules/

# Build folders, if tooling is added later
dist/
build/

# NOTE: assets/js/*.js and assets/images/*-<width>.{webp,jpg} are generated but
# ARE committed on purpose — static hosts (GitHub Pages) serve this repo
# directly with no build step. Regenerate with `npm run build` / `npm run images`.
